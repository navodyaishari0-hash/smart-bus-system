DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=smart_bus_system
DB_DIALECT=mysql
JWT_SECRET=supersecretjwtkey12345
CLIENT_URL=http://localhost:5173
